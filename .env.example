APP_NAME="Portal de Capacitacion Mr. Lana"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# En desarrollo con WAMP se recomienda mariadb/mysql (no sqlite), para reflejar el motor real de produccion.
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=capacitaciones
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Cola "database" es valida para desarrollo; en produccion se recomienda Redis (ver docs/COLAS_Y_SCHEDULER.md).
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ==================================================================
# Las siguientes variables corresponden a fases posteriores del
# proyecto (biblioteca multimedia/NAS, video, sesiones en vivo,
# notificaciones). Se documentan desde ahora para no reabrir este
# archivo varias veces, pero permanecen sin activar hasta su fase.
# Ver docs/PLAN_IMPLEMENTACION.md para el detalle de cada fase.
# ==================================================================

# --- Almacenamiento NAS (Fase 3) ---
# NAS_DRIVER=local
# NAS_ROOT=/mnt/mrlana-capacitacion
# NAS_HOST=
# NAS_PORT=22
# NAS_USERNAME=
# NAS_PASSWORD=
# NAS_PRIVATE_KEY=
# NAS_PATH_PREFIX=

# --- Procesamiento de video (Fase 3) ---
# FFMPEG_BIN=/usr/bin/ffmpeg
# FFPROBE_BIN=/usr/bin/ffprobe
# MEDIA_TOKEN_TTL=600
# MEDIA_ALLOWED_ORIGIN=
# MEDIA_MAX_UPLOAD_MB=
# VIDEO_COMPLETION_PERCENT=98
# VIDEO_HEARTBEAT_SECONDS=8
# VIDEO_PLAYBACK_RATE=1

# --- X-Accel-Redirect / Nginx (Fase 9) ---
# Solo activar en producción, detrás de Nginx, con deploy/nginx/multimedia.conf
# ya aplicado. En este entorno de desarrollo (WAMP, sin Nginx) debe quedar en
# false: el streaming directo por PHP sigue siendo correcto, solo más lento.
# MEDIA_X_ACCEL_REDIRECT=false
# MEDIA_X_ACCEL_INTERNAL_PREFIX=/protegido-nas

# --- Carga de video por bloques reanudable (Fase 9) ---
# MEDIA_CHUNK_SIZE_MB=8
# MEDIA_CARGA_EXPIRA_HORAS=24

# --- Google Meet (Fase 5, ampliado en Fase 9 con sincronización de asistencia) ---
# GOOGLE_MEET_ENABLED=false
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# GOOGLE_SERVICE_ACCOUNT_PATH=
# GOOGLE_IMPERSONATED_USER=
# GOOGLE_WORKSPACE_CUSTOMER_ID=
# GOOGLE_CALENDAR_ID=primary

# --- Zoom (Fase 5, ampliado en Fase 9 con reportes y webhooks) ---
# ZOOM_ENABLED=false
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_WEBHOOK_SECRET=
# ZOOM_HOST_EMAIL=

# --- Telegram (preparado para segunda fase de notificaciones) ---
# TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_DEFAULT_CHAT_ID=
